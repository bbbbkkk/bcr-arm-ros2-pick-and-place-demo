<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ===================================================== -->
  <!-- Controllable Parallel Gripper                         -->
  <!-- Logic kept:                                           -->
  <!--   gripper_left_finger_joint                           -->
  <!--   gripper_right_finger_joint                          -->
  <!--   both prismatic joints                               -->
  <!-- Convention:                                           -->
  <!--   0.000 = close / minimum gap, no overlap              -->
  <!--   0.015 = grasp 0.08m cube approximately              -->
  <!--   0.035 = open, gap > 0.08m                            -->
  <!-- ===================================================== -->

  <xacro:macro name="bcr_arm_fixed_gripper" params="parent_link:=tool0 prefix:=gripper_">

    <!-- ========================= -->
    <!-- Gripper base / palm       -->
    <!-- ========================= -->
    <link name="${prefix}base_link">

      <visual>
        <origin xyz="0 0 0.035" rpy="0 0 0"/>
        <geometry>
          <box size="0.09 0.08 0.07"/>
        </geometry>
        <material name="${prefix}dark_gray">
          <color rgba="0.12 0.12 0.12 1.0"/>
        </material>
      </visual>

      <visual>
        <origin xyz="0 0 0.080" rpy="0 0 0"/>
        <geometry>
          <box size="0.11 0.09 0.02"/>
        </geometry>
        <material name="${prefix}black">
          <color rgba="0.03 0.03 0.03 1.0"/>
        </material>
      </visual>

      <visual>
        <origin xyz="0.035 0 0.040" rpy="0 0 0"/>
        <geometry>
          <box size="0.02 0.08 0.055"/>
        </geometry>
        <material name="${prefix}gray">
          <color rgba="0.35 0.35 0.35 1.0"/>
        </material>
      </visual>

      <inertial>
        <origin xyz="0 0 0.04" rpy="0 0 0"/>
        <mass value="0.15"/>
        <inertia
          ixx="0.0001" ixy="0.0" ixz="0.0"
          iyy="0.0001" iyz="0.0"
          izz="0.0001"/>
      </inertial>
    </link>

    <joint name="${prefix}base_fixed_joint" type="fixed">
      <parent link="${parent_link}"/>
      <child link="${prefix}base_link"/>
      <origin xyz="0 0 0.08" rpy="0 0 0"/>
    </joint>


    <!-- ========================= -->
    <!-- Horizontal slider rail    -->
    <!-- ========================= -->
    <link name="${prefix}slider_bar_link">

      <visual>
        <origin xyz="0 0 0.020" rpy="0 0 0"/>
        <geometry>
          <box size="0.09 0.20 0.022"/>
        </geometry>
        <material name="${prefix}metal_gray">
          <color rgba="0.55 0.55 0.55 1.0"/>
        </material>
      </visual>

      <visual>
        <origin xyz="0.032 0 0.043" rpy="0 0 0"/>
        <geometry>
          <box size="0.022 0.21 0.022"/>
        </geometry>
        <material name="${prefix}light_gray">
          <color rgba="0.65 0.65 0.65 1.0"/>
        </material>
      </visual>

      <inertial>
        <origin xyz="0 0 0.02" rpy="0 0 0"/>
        <mass value="0.08"/>
        <inertia
          ixx="0.00005" ixy="0.0" ixz="0.0"
          iyy="0.00005" iyz="0.0"
          izz="0.00005"/>
      </inertial>
    </link>

    <joint name="${prefix}slider_bar_fixed_joint" type="fixed">
      <parent link="${prefix}base_link"/>
      <child link="${prefix}slider_bar_link"/>
      <origin xyz="0 0 0.08" rpy="0 0 0"/>
    </joint>

    <!-- ========================= -->
    <!-- Left finger assembly      -->
    <!-- ========================= -->
    <link name="${prefix}left_finger_link">

      <visual>
        <origin xyz="0 0 0.020" rpy="0 0 0"/>
        <geometry>
          <box size="0.045 0.030 0.04"/>
        </geometry>
        <material name="${prefix}left_slider">
          <color rgba="0.18 0.25 0.42 1.0"/>
        </material>
      </visual>

      <visual>
        <origin xyz="0 0 0.115" rpy="0 0 0"/>
        <geometry>
          <box size="0.028 0.022 0.18"/>
        </geometry>
        <material name="${prefix}blue">
          <color rgba="0.10 0.25 0.65 1.0"/>
        </material>
      </visual>

      <!-- 左夹爪内侧夹持垫：靠近 +Y 方向 -->
      <visual>
        <origin xyz="0.018 0.010 0.175" rpy="0 0 0"/>
        <geometry>
          <box size="0.024 0.010 0.055"/>
        </geometry>
        <material name="${prefix}rubber">
          <color rgba="0.02 0.02 0.02 1.0"/>
        </material>
      </visual>

      <visual>
        <origin xyz="-0.012 -0.006 0.105" rpy="0 0 0.20"/>
        <geometry>
          <box size="0.012 0.018 0.15"/>
        </geometry>
        <material name="${prefix}blue_dark">
          <color rgba="0.06 0.16 0.45 1.0"/>
        </material>
      </visual>

      <!-- 物理抓取用 collision：左夹爪主体 -->
      <collision name="left_finger_body_collision">
        <origin xyz="0 0 0.115" rpy="0 0 0"/>
        <geometry>
          <box size="0.028 0.022 0.18"/>
        </geometry>
      </collision>

      <!-- 物理抓取用 collision：左夹爪内侧夹持垫 -->
      <collision name="left_finger_inner_pad_collision">
        <origin xyz="0.018 0.010 0.175" rpy="0 0 0"/>
        <geometry>
          <box size="0.024 0.010 0.055"/>
        </geometry>
      </collision>

      <inertial>
        <origin xyz="0 0 0.10" rpy="0 0 0"/>
        <mass value="0.05"/>
        <inertia
          ixx="0.00005" ixy="0.0" ixz="0.0"
          iyy="0.00005" iyz="0.0"
          izz="0.00005"/>
      </inertial>
    </link>

    <!--
      左指初始在 y=-0.035。
      axis = -Y，所以 q 增大时向外打开。
    -->
    <joint name="${prefix}left_finger_joint" type="prismatic">
      <parent link="${prefix}slider_bar_link"/>
      <child link="${prefix}left_finger_link"/>
      <origin xyz="0 -0.035 0.035" rpy="0 0 0"/>
      <axis xyz="0 -1 0"/>
      <limit lower="0.0" upper="0.06" effort="30.0" velocity="0.05"/>
    </joint>

    <!-- ========================= -->
    <!-- Right finger assembly     -->
    <!-- ========================= -->
    <link name="${prefix}right_finger_link">

      <visual>
        <origin xyz="0 0 0.020" rpy="0 0 0"/>
        <geometry>
          <box size="0.045 0.030 0.04"/>
        </geometry>
        <material name="${prefix}right_slider">
          <color rgba="0.18 0.25 0.42 1.0"/>
        </material>
      </visual>

      <visual>
        <origin xyz="0 0 0.115" rpy="0 0 0"/>
        <geometry>
          <box size="0.028 0.022 0.18"/>
        </geometry>
        <material name="${prefix}blue"/>
      </visual>

      <!-- 右夹爪内侧夹持垫：靠近 -Y 方向 -->
      <visual>
        <origin xyz="0.018 -0.010 0.175" rpy="0 0 0"/>
        <geometry>
          <box size="0.024 0.010 0.055"/>
        </geometry>
        <material name="${prefix}rubber"/>
      </visual>

      <visual>
        <origin xyz="-0.012 0.006 0.105" rpy="0 0 -0.20"/>
        <geometry>
          <box size="0.012 0.018 0.15"/>
        </geometry>
        <material name="${prefix}blue_dark"/>
      </visual>

      <!-- 物理抓取用 collision：右夹爪主体 -->
      <collision name="right_finger_body_collision">
        <origin xyz="0 0 0.115" rpy="0 0 0"/>
        <geometry>
          <box size="0.028 0.022 0.18"/>
        </geometry>
      </collision>

      <!-- 物理抓取用 collision：右夹爪内侧夹持垫 -->
      <collision name="right_finger_inner_pad_collision">
        <origin xyz="0.018 -0.010 0.175" rpy="0 0 0"/>
        <geometry>
          <box size="0.024 0.010 0.055"/>
        </geometry>
      </collision>

      <inertial>
        <origin xyz="0 0 0.10" rpy="0 0 0"/>
        <mass value="0.05"/>
        <inertia
          ixx="0.00005" ixy="0.0" ixz="0.0"
          iyy="0.00005" iyz="0.0"
          izz="0.00005"/>
      </inertial>
    </link>

    <!--
      右指初始在 y=+0.035。
      axis = +Y，所以 q 增大时向外打开。
    -->
    <joint name="${prefix}right_finger_joint" type="prismatic">
      <parent link="${prefix}slider_bar_link"/>
      <child link="${prefix}right_finger_link"/>
      <origin xyz="0 0.035 0.035" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="0.0" upper="0.06" effort="30.0" velocity="0.05"/>
    </joint>

  </xacro:macro>

</robot>