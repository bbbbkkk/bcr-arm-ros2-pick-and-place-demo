<?xml version="1.0"?>
<robot name="bcr_arm" xmlns:xacro="http://www.ros.org/wiki/xacro">
<!-- 包含所有的头文件 -->
<xacro:include filename="$(find bcr_arm_description)/urdf/bcr_arm_ros2_controllers.xacro"/>
<xacro:include filename="$(find bcr_arm_description)/urdf/bcr_arm_materials.xacro"/>
<xacro:include filename="$(find bcr_arm_description)/urdf/bcr_arm_links_macros.xacro"/>
  

  <!-- ========================= -->
  <!-- Fixed world frame for Gazebo -->
  <link name="world"/>

  <joint name="world_to_base" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ========================= -->
  <!-- Base link -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.18" length="0.10"/>
      </geometry>
      <material name="black"/>
    </visual>

    <collision>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.18" length="0.10"/>
      </geometry>
    </collision>

    <xacro:cylinder_inertial mass="5.0" radius="0.18" length="0.10"/>
  </link>

  <!-- ========================= -->
  <!-- Arm links -->
  <!-- ========================= -->
  <!-- 这里使用的就是bcr_arm_links_macros -->
  <xacro:cylinder_link name="link1" length="0.30" radius="0.055" color="gray"   mass="1.5"/>
  <xacro:cylinder_link name="link2" length="0.35" radius="0.050" color="blue"   mass="1.3"/>
  <xacro:cylinder_link name="link3" length="0.30" radius="0.045" color="gray"   mass="1.1"/>
  <xacro:cylinder_link name="link4" length="0.25" radius="0.040" color="blue"   mass="0.9"/>
  <xacro:cylinder_link name="link5" length="0.20" radius="0.035" color="gray"   mass="0.7"/>
  <xacro:cylinder_link name="link6" length="0.16" radius="0.030" color="blue"   mass="0.5"/>
  <xacro:cylinder_link name="link7" length="0.12" radius="0.025" color="orange" mass="0.4"/>

  <!-- Tool frame -->
  <link name="tool0">
    <visual>
      <origin xyz="0 0 0.04" rpy="0 0 0"/>
      <geometry>
        <box size="0.08 0.04 0.08"/>
      </geometry>
      <material name="orange"/>
    </visual>

    <collision>
      <origin xyz="0 0 0.04" rpy="0 0 0"/>
      <geometry>
        <box size="0.08 0.04 0.08"/>
      </geometry>
    </collision>

    <xacro:box_inertial mass="0.3" x="0.08" y="0.04" z="0.08"/>
  </link>

  <!-- ========================= -->
  <!-- 7-DOF joints -->
  <!-- ========================= -->

  <!-- joint1: base yaw -->
  <joint name="joint1" type="revolute">
    <parent link="base_link"/>
    <child link="link1"/>
    <origin xyz="0 0 0.10" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.1416" upper="3.1416" effort="100.0" velocity="1.5"/>
  </joint>

  <!-- joint2: shoulder pitch -->
  <joint name="joint2" type="revolute">
    <parent link="link1"/>
    <child link="link2"/>
    <origin xyz="0 0 0.30" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.2" upper="2.2" effort="100.0" velocity="1.5"/>
  </joint>

  <!-- joint3: elbow pitch -->
  <joint name="joint3" type="revolute">
    <parent link="link2"/>
    <child link="link3"/>
    <origin xyz="0 0 0.35" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.2" upper="2.2" effort="100.0" velocity="1.5"/>
  </joint>

  <!-- joint4: wrist roll -->
  <joint name="joint4" type="revolute">
    <parent link="link3"/>
    <child link="link4"/>
    <origin xyz="0 0 0.30" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-3.1416" upper="3.1416" effort="80.0" velocity="1.5"/>
  </joint>

  <!-- joint5: wrist pitch -->
  <joint name="joint5" type="revolute">
    <parent link="link4"/>
    <child link="link5"/>
    <origin xyz="0 0 0.25" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.2" upper="2.2" effort="80.0" velocity="1.5"/>
  </joint>

  <!-- joint6: wrist roll -->
  <joint name="joint6" type="revolute">
    <parent link="link5"/>
    <child link="link6"/>
    <origin xyz="0 0 0.20" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-3.1416" upper="3.1416" effort="60.0" velocity="1.5"/>
  </joint>

  <!-- joint7: final pitch -->
  <joint name="joint7" type="revolute">
    <parent link="link6"/>
    <child link="link7"/>
    <origin xyz="0 0 0.16" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.2" upper="2.2" effort="60.0" velocity="1.5"/>
  </joint>

  <!-- fixed tool joint -->
  <joint name="tool_joint" type="fixed">
    <parent link="link7"/>
    <child link="tool0"/>
    <origin xyz="0 0 0.12" rpy="0 0 0"/>
  </joint>

<!-- ros2_control 硬件接口 + Gazebo 插件 -->
<!-- 加载控制器配置文件，连接仿真器与控制系统 -->
  <xacro:bcr_arm_ros2_control name="bcr_arm_system"/>
</robot>